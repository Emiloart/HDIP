# Phase 1 production/pilot environment template.
# Placeholder values only. Inject real values from the deployment secret manager.

HDIP_ENVIRONMENT=production
HDIP_LOG_LEVEL=INFO

# Public issuer/verifier API auth. Production must use Hydra mode.
HDIP_PUBLIC_AUTH_MODE=hydra
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_URL=<private-hydra-admin-introspection-url>
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_CLIENT_ID=<resource-server-introspection-client-id>
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_CLIENT_SECRET=<resource-server-introspection-client-secret>

# Phase 1 SQL runtime.
HDIP_PHASE1_DATABASE_DRIVER=pgx
HDIP_PHASE1_DATABASE_URL=<postgresql-dsn-from-secret-manager>

# Verifier API internal trust-registry access.
HDIP_TRUST_REGISTRY_BASE_URL=<private-trust-registry-url>
HDIP_TRUST_RUNTIME_HYDRA_TOKEN_URL=<hydra-public-token-url>
HDIP_TRUST_RUNTIME_HYDRA_CLIENT_ID=<verifier-runtime-client-id>
HDIP_TRUST_RUNTIME_HYDRA_CLIENT_SECRET=<verifier-runtime-client-secret>
HDIP_TRUST_RUNTIME_HYDRA_SCOPE=trust.runtime.read

# Trust-registry internal introspection for verifier runtime reads.
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_URL=<private-hydra-admin-introspection-url>
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_CLIENT_ID=<trust-registry-introspection-client-id>
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_CLIENT_SECRET=<trust-registry-introspection-client-secret>
HDIP_TRUST_RUNTIME_HYDRA_EXPECTED_CLIENT_ID=<verifier-runtime-client-id>
HDIP_TRUST_RUNTIME_HYDRA_REQUIRED_SCOPE=trust.runtime.read
