# Phase 1 production/pilot environment template.
# Placeholder values only. Inject real values from the deployment secret manager.

HDIP_ENVIRONMENT=production
HDIP_LOG_LEVEL=INFO

# First controlled pilot profile.
# Public ingress is Cloudflare. Real values live in Vault, not this file.
HDIP_PILOT_DOMAIN=<pilot-domain>
HDIP_CLOUDFLARE_ZONE_ID=<cloudflare-zone-id>

# Single-VM Compose bootstrap values.
# Use strong generated values from Vault. Do not use local .env.example values.
POSTGRES_PASSWORD=<postgres-password-from-vault>
HYDRA_SYSTEM_SECRET=<hydra-system-secret-from-vault>
HYDRA_SELF_ISSUER_URL=https://auth.<pilot-domain>

# Public issuer/verifier API auth. Production must use Hydra mode.
HDIP_PUBLIC_AUTH_MODE=hydra
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_URL=<private-hydra-admin-introspection-url>
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_CLIENT_ID=<resource-server-introspection-client-id>
HDIP_PUBLIC_AUTH_HYDRA_INTROSPECTION_CLIENT_SECRET=<resource-server-introspection-client-secret>

# Phase 1 SQL runtime.
HDIP_PHASE1_DATABASE_DRIVER=pgx
HDIP_PHASE1_DATABASE_URL=<postgresql-dsn-from-secret-manager>

# Verifier API internal trust-registry access.
HDIP_TRUST_REGISTRY_BASE_URL=<private-trust-registry-url>
HDIP_TRUST_RUNTIME_HYDRA_TOKEN_URL=<hydra-public-token-url>
HDIP_TRUST_RUNTIME_HYDRA_CLIENT_ID=<verifier-runtime-client-id>
HDIP_TRUST_RUNTIME_HYDRA_CLIENT_SECRET=<verifier-runtime-client-secret>
HDIP_TRUST_RUNTIME_HYDRA_SCOPE=trust.runtime.read

# Trust-registry internal introspection for verifier runtime reads.
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_URL=<private-hydra-admin-introspection-url>
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_CLIENT_ID=<trust-registry-introspection-client-id>
HDIP_TRUST_RUNTIME_HYDRA_INTROSPECTION_CLIENT_SECRET=<trust-registry-introspection-client-secret>
HDIP_TRUST_RUNTIME_HYDRA_EXPECTED_CLIENT_ID=<verifier-runtime-client-id>
HDIP_TRUST_RUNTIME_HYDRA_REQUIRED_SCOPE=trust.runtime.read

# Compose client bootstrap values for the controlled pilot.
# If clients are provisioned manually after Hydra starts, mirror the same values in Vault.
VERIFIER_TRUST_CLIENT_ID=<verifier-runtime-client-id>
VERIFIER_TRUST_CLIENT_SECRET=<verifier-runtime-client-secret>
TRUST_REGISTRY_INTROSPECTION_CLIENT_ID=<trust-registry-introspection-client-id>
TRUST_REGISTRY_INTROSPECTION_CLIENT_SECRET=<trust-registry-introspection-client-secret>
TRUST_RUNTIME_SCOPE=trust.runtime.read
ISSUER_API_INTROSPECTION_CLIENT_ID=<issuer-api-introspection-client-id>
ISSUER_API_INTROSPECTION_CLIENT_SECRET=<issuer-api-introspection-client-secret>
VERIFIER_API_INTROSPECTION_CLIENT_ID=<verifier-api-introspection-client-id>
VERIFIER_API_INTROSPECTION_CLIENT_SECRET=<verifier-api-introspection-client-secret>
ISSUER_PUBLIC_CLIENT_ID=<issuer-organization-id>
ISSUER_PUBLIC_CLIENT_SECRET=<issuer-public-client-secret-from-vault>
ISSUER_PUBLIC_SCOPE=issuer.credentials.issue issuer.credentials.read issuer.credentials.status.write
VERIFIER_PUBLIC_CLIENT_ID=<verifier-organization-id>
VERIFIER_PUBLIC_CLIENT_SECRET=<verifier-public-client-secret-from-vault>
VERIFIER_PUBLIC_SCOPE=verifier.requests.create verifier.results.read
