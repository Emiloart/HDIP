# Local-only defaults for the Phase 1 Docker Compose sandbox.
# Replace every value before using this outside a local developer machine.

POSTGRES_PASSWORD=hdip_sandbox_password
HYDRA_SYSTEM_SECRET=hdip_sandbox_system_secret_32_bytes
VERIFIER_TRUST_CLIENT_ID=verifier-api
VERIFIER_TRUST_CLIENT_SECRET=verifier-runtime-secret
TRUST_REGISTRY_INTROSPECTION_CLIENT_ID=trust-registry
TRUST_REGISTRY_INTROSPECTION_CLIENT_SECRET=trust-registry-introspection-secret
TRUST_RUNTIME_SCOPE=trust.runtime.read

ISSUER_API_INTROSPECTION_CLIENT_ID=issuer-api
ISSUER_API_INTROSPECTION_CLIENT_SECRET=issuer-api-introspection-secret
VERIFIER_API_INTROSPECTION_CLIENT_ID=verifier-api-public
VERIFIER_API_INTROSPECTION_CLIENT_SECRET=verifier-api-introspection-secret

ISSUER_PUBLIC_CLIENT_ID=did:web:issuer.hdip.dev
ISSUER_PUBLIC_CLIENT_SECRET=issuer-public-client-secret
ISSUER_PUBLIC_SCOPE=issuer.credentials.issue issuer.credentials.read issuer.credentials.status.write
VERIFIER_PUBLIC_CLIENT_ID=verifier_org_sandbox
VERIFIER_PUBLIC_CLIENT_SECRET=verifier-public-client-secret
VERIFIER_PUBLIC_SCOPE=verifier.requests.create verifier.results.read
