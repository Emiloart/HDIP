{
  "name": "hdip",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "schema:validate": "node scripts/validate-schemas.mjs",
    "validate:web": "npm run lint && npm run typecheck && npm run test && npm run schema:validate"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
