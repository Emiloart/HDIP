{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/issuer/credential-status-update-request.schema.json",
  "title": "CredentialStatusUpdateRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "revoked",
        "superseded"
      ]
    },
    "supersededByCredentialId": {
      "type": "string",
      "minLength": 1
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "const": "revoked"
        }
      },
      "not": {
        "type": "object",
        "required": [
          "supersededByCredentialId"
        ],
        "properties": {
          "supersededByCredentialId": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "type": "object",
      "required": [
        "status",
        "supersededByCredentialId"
      ],
      "properties": {
        "status": {
          "const": "superseded"
        },
        "supersededByCredentialId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  ]
}
