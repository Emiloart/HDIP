{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/credentials/issuance-request.schema.json",
  "title": "IssuanceRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "templateId",
    "subjectReference",
    "claims"
  ],
  "properties": {
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "subjectReference": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fullLegalName",
        "dateOfBirth",
        "countryOfResidence",
        "documentCountry",
        "kycLevel",
        "verifiedAt",
        "expiresAt"
      ],
      "properties": {
        "fullLegalName": {
          "type": "string",
          "minLength": 1
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date"
        },
        "countryOfResidence": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "documentCountry": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "kycLevel": {
          "type": "string",
          "minLength": 1
        },
        "verifiedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
