{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/credentials/issuance-response.schema.json",
  "title": "IssuanceResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credentialId",
    "issuerId",
    "templateId",
    "status",
    "issuedAt",
    "expiresAt",
    "statusReference",
    "credentialArtifact"
  ],
  "properties": {
    "credentialId": {
      "type": "string",
      "minLength": 1
    },
    "issuerId": {
      "type": "string",
      "minLength": 1
    },
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "superseded"
      ]
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "statusReference": {
      "type": "string",
      "minLength": 1
    },
    "credentialArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "mediaType",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "phase1_opaque_artifact"
        },
        "mediaType": {
          "type": "string",
          "const": "application/vnd.hdip.phase1-opaque-artifact"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
