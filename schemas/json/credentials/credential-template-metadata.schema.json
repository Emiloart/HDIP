{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/credentials/credential-template-metadata.schema.json",
  "title": "CredentialTemplateMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "templateId",
    "displayName",
    "version",
    "credentialTypes"
  ],
  "properties": {
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "credentialTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
