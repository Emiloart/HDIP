{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/credentials/credential-record.schema.json",
  "title": "CredentialRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credentialId",
    "issuerId",
    "templateId",
    "subjectReference",
    "claims",
    "artifactDigest",
    "status",
    "statusReference",
    "issuedAt",
    "expiresAt",
    "statusUpdatedAt"
  ],
  "properties": {
    "credentialId": {
      "type": "string",
      "minLength": 1
    },
    "issuerId": {
      "type": "string",
      "minLength": 1
    },
    "templateId": {
      "type": "string",
      "minLength": 1
    },
    "subjectReference": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fullLegalName",
        "dateOfBirth",
        "countryOfResidence",
        "documentCountry",
        "kycLevel",
        "verifiedAt",
        "expiresAt"
      ],
      "properties": {
        "fullLegalName": {
          "type": "string",
          "minLength": 1
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date"
        },
        "countryOfResidence": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "documentCountry": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "kycLevel": {
          "type": "string",
          "minLength": 1
        },
        "verifiedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "artifactDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "superseded"
      ]
    },
    "statusReference": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "statusUpdatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "supersededByCredentialId": {
      "type": "string",
      "minLength": 1
    },
    "credentialArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "mediaType",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "phase1_opaque_artifact"
        },
        "mediaType": {
          "type": "string",
          "const": "application/vnd.hdip.phase1-opaque-artifact"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifactReference": {
      "type": "string",
      "minLength": 1
    }
  },
  "oneOf": [
    {
      "required": [
        "credentialArtifact"
      ],
      "properties": {
        "credentialArtifact": {
          "type": "object"
        },
        "artifactReference": false
      }
    },
    {
      "required": [
        "artifactReference"
      ],
      "properties": {
        "artifactReference": {
          "type": "string"
        },
        "credentialArtifact": false
      }
    }
  ]
}
