{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/credentials/credential-status.schema.json",
  "title": "CredentialStatus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credentialId",
    "status",
    "statusReference",
    "statusUpdatedAt",
    "expiresAt"
  ],
  "properties": {
    "credentialId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "superseded"
      ]
    },
    "statusReference": {
      "type": "string",
      "minLength": 1
    },
    "statusUpdatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "supersededByCredentialId": {
      "type": "string",
      "minLength": 1
    }
  }
}
