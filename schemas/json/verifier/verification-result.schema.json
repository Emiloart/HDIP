{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/verifier/verification-result.schema.json",
  "title": "VerificationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verificationId",
    "issuerId",
    "decision",
    "reasonCodes",
    "evaluatedAt",
    "credentialStatus"
  ],
  "properties": {
    "verificationId": {
      "type": "string",
      "minLength": 1
    },
    "credentialId": {
      "type": "string",
      "minLength": 1
    },
    "issuerId": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "review"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "credentialStatus": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "superseded",
        "expired"
      ]
    }
  }
}
