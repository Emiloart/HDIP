{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/verifier/verifier-result.schema.json",
  "title": "VerifierResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "decision",
    "reasons"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "review"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
