{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdip.dev/schemas/common/health.schema.json",
  "title": "HealthResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "service",
    "version"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "ready"
      ]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  }
}
